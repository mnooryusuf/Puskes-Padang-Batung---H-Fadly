<?php

namespace App\Filament\Widgets;

use App\Models\Pendaftaran;
use App\Models\Poli;
use Filament\Widgets\ChartWidget;

class SebaranPoliChart extends ChartWidget
{
    protected static ?string $heading = 'Distribusi Pasien per Poli';
    protected static ?int $sort = 3;

    public static function canView(): bool
    {
        return !auth()->user()?->hasRole('pasien');
    }

    protected function getData(): array
    {
        $polis = Poli::withCount('pendaftarans')->get();

        return [
            'datasets' => [
                [
                    'label' => 'Pasien',
                    'data' => $polis->pluck('pendaftarans_count')->toArray(),
                    'backgroundColor' => [
                        '#00796B', '#FF9800', '#F44336', '#2196F3', '#9C27B0'
                    ],
                ],
            ],
            'labels' => $polis->pluck('nama_poli')->toArray(),
        ];
    }

    protected function getType(): string
    {
        return 'pie';
    }
}
